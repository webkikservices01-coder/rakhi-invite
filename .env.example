# Marvels AI chatbot (api/chat.js) — server-side only, never VITE_-prefixed.
# Without this the chat widget silently falls back to the offline rule-based responder.
ANTHROPIC_API_KEY=

# Copy relevant keys to .env.local for local dev, and add the same in
# Vercel -> Project Settings -> Environment Variables for deploys.

# --- Frontend (exposed to browser, must be prefixed VITE_) ---
VITE_CASHFREE_ENV=production
VITE_API_URL=

# --- Backend (serverless functions only, never sent to browser) ---
CASHFREE_ENV=production
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

FRONTEND_URL=https://your-domain.vercel.app

# Refrens invoicing (https://www.refrens.com/api/docs/) - optional, best-effort
REFRENS_APP_ID=
REFRENS_URL_KEY=
REFRENS_APP_SECRET=
